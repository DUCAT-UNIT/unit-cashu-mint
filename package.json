{
  "name": "@ducat/mint-server",
  "version": "0.1.0",
  "description": "Cashu ecash mint backed by Bitcoin Runes",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node scripts/dev/run-vitest-local.mjs --run",
    "test:unit": "node scripts/dev/run-vitest-local.mjs --run",
    "test:watch": "node scripts/dev/run-vitest-local.mjs",
    "test:coverage": "node scripts/dev/run-vitest-local.mjs --run --coverage",
    "test:integration": "node scripts/dev/run-integration-tests.mjs",
    "test:interop": "npm run interop:cashu-ts && npm run interop:cdk && npm run interop:nutshell",
    "interop:cashu-ts": "tsx scripts/interop/cashu-ts-wallet-flow.ts",
    "interop:cdk": "bash scripts/interop/cdk-wallet-flow.sh",
    "interop:nutshell": "bash scripts/interop/nutshell-wallet-flow.sh",
    "gcp:confidential-space:build": "node scripts/gcp-confidential-space-build.mjs",
    "gcp:confidential-space:attest": "node scripts/gcp-confidential-space-attest.mjs",
    "gcp:confidential-space:audit": "node scripts/gcp-confidential-space-audit-monitor.mjs",
    "migrations:check": "node scripts/check-migrations.mjs",
    "scripts:check": "node --check scripts/check-migrations.mjs && node --check scripts/dev/run-integration-tests.mjs && node --check scripts/dev/run-vitest-local.mjs && node --check scripts/gcp-confidential-space-attest.mjs && node --check scripts/gcp-confidential-space-audit-monitor.mjs && node --check scripts/gcp-confidential-space-build.mjs && node --check scripts/gcp-confidential-space-caddy-storage.mjs && node --check scripts/gcp-confidential-space-env.mjs && node --check scripts/interop/fake-ln-invoice.mjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "tsx src/scripts/migrate.ts"
  },
  "keywords": [
    "cashu",
    "ecash",
    "runes",
    "bitcoin",
    "mint"
  ],
  "author": "Ducat Protocol",
  "license": "MIT",
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@cashu/cashu-ts": "4.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@scure/base": "^2.2.0",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.5",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "pg": "^8.11.5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.4.0"
  }
}
