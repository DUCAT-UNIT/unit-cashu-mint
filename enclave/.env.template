# Ducat Cashu Mint - Enclave Environment Template
# This file contains placeholder values for enclave deployment
# Actual secrets are unsealed from KMS at runtime

# =============================================================================
# Core Configuration
# =============================================================================

# Environment (production | development | test)
NODE_ENV=production

# Server binding (inside enclave)
PORT=3338
HOST=127.0.0.1

# Enable enclave-specific features
ENCLAVE_MODE=true

# =============================================================================
# Database Configuration
# All database connections go through vsock to parent instance
# =============================================================================

# PostgreSQL connection (via vsock proxy)
# Format: postgresql://user:password@localhost:5432/database
DATABASE_URL=postgresql://mintuser:CHANGE_ME@localhost:5432/mintdb

# Redis connection (via vsock proxy, optional)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Bitcoin Network Configuration
# All external APIs are accessed via vsock proxies
# =============================================================================

# Bitcoin network
# Options: mainnet | testnet | signet | regtest | mutinynet
NETWORK=mainnet

# Blockchain APIs (routed through vsock)
# localhost:8332 -> parent vsock proxy -> Ord API
ORD_URL=http://localhost:8332

# localhost:8333 -> parent vsock proxy -> Esplora API
ESPLORA_URL=http://localhost:8333

# localhost:8334 -> parent vsock proxy -> Mempool API
MEMPOOL_URL=http://localhost:8334

# =============================================================================
# Cryptographic Secrets (UNSEALED FROM KMS AT RUNTIME)
# DO NOT hardcode these values - they are populated by unseal-secrets.sh
# =============================================================================

# 32-byte hex seed for deterministic key derivation
# Generated on first boot and sealed to KMS
MINT_SEED=

# 32-byte hex key for encrypting private keys in database
# Generated on first boot and sealed to KMS
ENCRYPTION_KEY=

# JWT secret for authentication
JWT_SECRET=

# =============================================================================
# Mint Identity
# =============================================================================

# Mint's public key (derived from MINT_SEED)
MINT_PUBKEY=

# =============================================================================
# Payment Backend Configuration
# =============================================================================

# Supported units (comma-separated: 'sat', 'btc', or 'sat,btc')
SUPPORTED_UNITS=sat

# --- Runes Backend (for 'sat' unit) ---

# Rune ID for the UNIT token (e.g., "840000:3")
SUPPORTED_RUNES=

# Mint's taproot address for receiving UNIT deposits
MINT_TAPROOT_ADDRESS=

# Mint's taproot internal pubkey (32-byte x-only key)
MINT_TAPROOT_PUBKEY=

# Mint's segwit address for paying fees
MINT_SEGWIT_ADDRESS=

# --- BTC Backend (for 'btc' unit) ---

# Mint's P2WPKH address for BTC deposits
MINT_BTC_ADDRESS=

# Public key for BTC signing
MINT_BTC_PUBKEY=

# Fee rate in sats/vbyte
BTC_FEE_RATE=5

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per window
RATE_LIMIT_MAX=100

# Window size in milliseconds
RATE_LIMIT_WINDOW=60000

# =============================================================================
# Mint Information
# =============================================================================

MINT_NAME=Ducat Cashu Mint
MINT_DESCRIPTION=Secure Cashu mint running in AWS Nitro Enclave
MINT_CONTACT_EMAIL=
MINT_CONTACT_NOSTR=

# =============================================================================
# Amount Limits
# =============================================================================

# Minimum/maximum mint amount (in base units)
MIN_MINT_AMOUNT=100
MAX_MINT_AMOUNT=100000000

# Minimum/maximum melt amount (in base units)
MIN_MELT_AMOUNT=100
MAX_MELT_AMOUNT=100000000

# =============================================================================
# Confirmation Requirements
# =============================================================================

# Required confirmations for deposits
MINT_CONFIRMATIONS=1

# Required confirmations for withdrawals
MELT_CONFIRMATIONS=1

# =============================================================================
# Logging
# =============================================================================

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# =============================================================================
# KMS Configuration (for secret unsealing)
# =============================================================================

# KMS key ARN for encrypting/decrypting secrets
KMS_KEY_ID=

# AWS region
AWS_REGION=us-east-1

# Path for storing encrypted secrets (inside enclave)
SECRETS_PATH=/run/secrets

# Set to "true" on first boot to generate new secrets
FIRST_BOOT=false

# =============================================================================
# vsock Configuration
# =============================================================================

# Parent instance CID (standard is 3)
VSOCK_CID=3
