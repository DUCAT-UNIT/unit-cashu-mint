# Copy to terraform.tfvars and fill in values.

project_id  = "your-gcp-project-id"
region      = "us-central1"
zone        = "us-central1-a"
environment = "prod"

domain_name = "cashu-mint.yourdomain.com"
tls_email   = "ops@yourdomain.com"

repo_url = "https://github.com/your-org/mint-server.git"
repo_ref = "main"

# Use "confidential-vm" for the current startup-script deployment.
# Use "confidential-space" for attestation-gated Secret Manager and KMS access
# bound to the workload container digest.
deployment_mode = "confidential-vm"

# Required only when deployment_mode = "confidential-space".
# Build and push gcp-confidential-space/Dockerfile, then pin the image by digest.
confidential_space_image_reference = "us-docker.pkg.dev/your-gcp-project-id/ducat-mint/mint-server@sha256:..."
confidential_space_image_digest    = "sha256:..."
confidential_space_image_family    = "confidential-space"

# N2D uses AMD SEV. For stronger hardware-backed attestation, choose a zone and
# machine family that supports SEV_SNP or TDX and set confidential_instance_type.
machine_type               = "n2d-standard-4"
confidential_instance_type = "SEV"
boot_disk_size_gb          = 50

mint_env_secret_id = "ducat-mint-env"

# Fails boot before fetching Secret Manager payload if this is not a
# Confidential VM with Shielded VM controls enabled.
require_confidential_vm_attestation = true

# Generate with: openssl rand -base64 24
db_password = "CHANGE_THIS_TO_A_SECURE_PASSWORD"

# Leave empty to disable direct SSH firewall access.
admin_cidr_blocks = []
